{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "$HOME/Work/claude-workspace/claude-vuejs-starterkit/.claude/slack-notify.sh stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "$HOME/Work/claude-workspace/claude-vuejs-starterkit/.claude/slack-notify.sh notification"
          }
        ]
      }
    ]
  }
}
